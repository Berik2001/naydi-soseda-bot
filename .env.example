# Скопируй этот файл в .env и подставь свои значения:
#   cp .env.example .env

# ====================== ОБЯЗАТЕЛЬНЫЕ ======================

# Токен бота от @BotFather
BOT_TOKEN=123456789:AA-replace-with-your-token

# Строка подключения к PostgreSQL.
# Для Supabase используй СТРОКУ ПУЛЕРА (Session Pooler) — она работает по IPv4.
# Dashboard -> Project Settings -> Database -> Connection string -> Session pooler.
# Если в пароле есть '@', закодируй его как %40.
# Пример (Supabase Session Pooler):
# postgresql://postgres.<project_ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roommate_bot


# ====================== ОПЦИОНАЛЬНЫЕ ======================

# FSM-хранилище. Если задан — состояние регистрации переживает рестарты и
# возможен горизонтальный масштаб (несколько инстансов). Если не задан —
# используется MemoryStorage (состояние теряется при рестарте, один инстанс).
# Формат Redis-протокола (TLS у Upstash — схема rediss://):
# rediss://default:<password>@<host>:6379
# REDIS_URL=

# Размер пула соединений asyncpg. Дефолты подобраны под Supabase Session Pooler
# (лимит ~15 клиентов) с учётом перекрытия контейнеров при деплое.
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=5

# Кэш prepared statements asyncpg. По умолчанию не трогаем. При переходе на
# Transaction-mode пулер Supabase (порт 6543) prepared statements ломаются —
# тогда выставь 0.
# DB_STATEMENT_CACHE_SIZE=0
